// ============================================================
// INVENTORY ROUTES
//
// POST /inventory/receive     → Staff scans a piece when it arrives
// POST /inventory/scan-sale   → Staff scans a piece for a walk-in customer
// GET  /inventory/piece/:jewelcode → Look up a single piece
// GET  /inventory/location/:location_id → See all pieces at a location
// ============================================================

const express = require('express')
const router = express.Router()
const supabase = require('../supabase')

// ----------------------------------------------------------
// POST /inventory/receive
// Called when a new physical piece arrives at a location
//
// Body: {
//   jewelcode: "AC-001234",
//   variant_id: "12345678901234",   ← from Shopify
//   sku: "RING-SOLI-001",
//   location_id: "HSR-BLR-STORE"
// }
// ----------------------------------------------------------
router.post('/receive', async (req, res) => {
  const { jewelcode, variant_id, sku, location_id } = req.body

  // --- Validate required fields ---
  if (!jewelcode || !location_id) {
    return res.status(400).json({
      success: false,
      error: 'jewelcode and location_id are required'
    })
  }

  // --- Check if this jewelcode already exists ---
  const { data: existing } = await supabase
    .from('inventory_pieces')
    .select('jewelcode, status')
    .eq('jewelcode', jewelcode)
    .single()

  if (existing) {
    return res.status(409).json({
      success: false,
      error: `Piece ${jewelcode} already exists in system`,
      current_status: existing.status
    })
  }

  // --- Check that location exists ---
  const { data: location } = await supabase
    .from('locations')
    .select('location_id, location_name')
    .eq('location_id', location_id)
    .eq('is_active', true)
    .single()

  if (!location) {
    return res.status(400).json({
      success: false,
      error: `Location ${location_id} not found or inactive`
    })
  }

  // --- Create the inventory piece ---
  const { data: piece, error } = await supabase
    .from('inventory_pieces')
    .insert({
      jewelcode,
      variant_id: variant_id || null,
      sku: sku || null,
      location_id,
      status: 'available'
    })
    .select()
    .single()

  if (error) {
    console.error('Error receiving piece:', error)
    return res.status(500).json({ success: false, error: error.message })
  }

  // --- Log this event ---
  await logEvent(jewelcode, 'receive', 'admin', {
    location_id,
    variant_id,
    sku
  })

  return res.json({
    success: true,
    message: `Piece ${jewelcode} received at ${location.location_name}`,
    piece
  })
})

// ----------------------------------------------------------
// POST /inventory/scan-sale
// Called when staff scans a piece for a walk-in customer at store
//
// Body: {
//   jewelcode: "AC-001234",
//   location_id: "HSR-BLR-STORE"
// }
// ----------------------------------------------------------
router.post('/scan-sale', async (req, res) => {
  const { jewelcode, location_id } = req.body

  if (!jewelcode || !location_id) {
    return res.status(400).json({
      success: false,
      error: 'jewelcode and location_id are required'
    })
  }

  // --- Find the piece ---
  const { data: piece } = await supabase
    .from('inventory_pieces')
    .select('*')
    .eq('jewelcode', jewelcode)
    .single()

  if (!piece) {
    await logEvent(jewelcode, 'fail', 'offline', { reason: 'piece_not_found', location_id })
    return res.status(404).json({
      success: false,
      error: `Piece ${jewelcode} not found in system`
    })
  }

  // --- Check if it's available ---
  if (piece.status !== 'available') {
    await logEvent(jewelcode, 'fail', 'offline', {
      reason: 'not_available',
      current_status: piece.status,
      location_id
    })
    return res.status(409).json({
      success: false,
      error: `Piece ${jewelcode} is not available. Current status: ${piece.status}`,
      piece
    })
  }

  // --- Check if it's at the right location ---
  if (piece.location_id !== location_id) {
    await logEvent(jewelcode, 'fail', 'offline', {
      reason: 'wrong_location',
      piece_location: piece.location_id,
      scan_location: location_id
    })
    return res.status(409).json({
      success: false,
      error: `Piece ${jewelcode} is at ${piece.location_id}, not at ${location_id}`,
      piece
    })
  }

  // --- Mark as allocated (hold it while draft order is being created) ---
  const { error: updateError } = await supabase
    .from('inventory_pieces')
    .update({ status: 'allocated', updated_at: new Date().toISOString() })
    .eq('jewelcode', jewelcode)

  if (updateError) {
    return res.status(500).json({ success: false, error: updateError.message })
  }

  await logEvent(jewelcode, 'scan', 'offline', { location_id, trigger: 'walk_in_sale' })

  return res.json({
    success: true,
    message: `Piece ${jewelcode} is available and has been held for sale`,
    piece: { ...piece, status: 'allocated' },
    next_step: 'Create a Shopify Draft Order and then call /inventory/confirm-sale'
  })
})

// ----------------------------------------------------------
// POST /inventory/confirm-sale
// Called after Draft Order is paid in POS — marks piece as sold
//
// Body: {
//   jewelcode: "AC-001234",
//   order_id: "SHOPIFY-ORDER-ID"
// }
// ----------------------------------------------------------
router.post('/confirm-sale', async (req, res) => {
  const { jewelcode, order_id } = req.body

  if (!jewelcode || !order_id) {
    return res.status(400).json({
      success: false,
      error: 'jewelcode and order_id are required'
    })
  }

  const { data: piece } = await supabase
    .from('inventory_pieces')
    .select('*')
    .eq('jewelcode', jewelcode)
    .single()

  if (!piece) {
    return res.status(404).json({ success: false, error: 'Piece not found' })
  }

  if (piece.status !== 'allocated') {
    return res.status(409).json({
      success: false,
      error: `Piece must be in 'allocated' status to confirm sale. Current: ${piece.status}`
    })
  }

  const { error } = await supabase
    .from('inventory_pieces')
    .update({
      status: 'sold',
      order_id,
      updated_at: new Date().toISOString()
    })
    .eq('jewelcode', jewelcode)

  if (error) return res.status(500).json({ success: false, error: error.message })

  await logEvent(jewelcode, 'sell', 'offline', { order_id })

  return res.json({
    success: true,
    message: `Piece ${jewelcode} marked as sold`,
    order_id
  })
})

// ----------------------------------------------------------
// GET /inventory/piece/:jewelcode
// Look up any piece by its barcode — useful for Retool dashboard
// ----------------------------------------------------------
router.get('/piece/:jewelcode', async (req, res) => {
  const { jewelcode } = req.params

  const { data: piece, error } = await supabase
    .from('inventory_pieces')
    .select('*, locations(location_name)')
    .eq('jewelcode', req.params.jewelcode)
    .single()

  if (!piece) {
    return res.status(404).json({ success: false, error: 'Piece not found' })
  }

  return res.json({ success: true, piece })
})

// ----------------------------------------------------------
// GET /inventory/location/:location_id
// See all pieces at a specific location — for Retool dashboard
// ----------------------------------------------------------
router.get('/location/:location_id', async (req, res) => {
  const { location_id } = req.params
  const { status } = req.query // optional filter: ?status=available

  let query = supabase
    .from('inventory_pieces')
    .select('*')
    .eq('location_id', location_id)
    .order('created_at', { ascending: false })

  if (status) {
    query = query.eq('status', status)
  }

  const { data: pieces, error } = await query

  if (error) return res.status(500).json({ success: false, error: error.message })

  return res.json({
    success: true,
    location_id,
    count: pieces.length,
    pieces
  })
})

// ----------------------------------------------------------
// HELPER: Log every action to inventory_events table
// ----------------------------------------------------------
async function logEvent(jewelcode, action, source, metadata = {}) {
  await supabase.from('inventory_events').insert({
    jewelcode,
    action,
    source,
    metadata,
    timestamp: new Date().toISOString()
  })
}

module.exports = router
